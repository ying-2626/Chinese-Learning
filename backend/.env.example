# 腾讯云语音评测配置
# 在腾讯云控制台获取: https://console.cloud.tencent.com/cam/capi
TENCENT_SOE_APPID=your_tencent_appid_here
TENCENT_SOE_SECRET_ID=your_tencent_secret_id_here
TENCENT_SOE_SECRET_KEY=your_tencent_secret_key_here

# FastGPT API 配置
# 在 FastGPT 控制台获取
FASTGPT_API_KEY=your_fastgpt_api_key_here

# 讯飞语音配置
# 在讯飞开放平台获取: https://www.xfyun.cn/
XUNFEI_APPID=your_xunfei_appid_here
XUNFEI_API_SECRET=your_xunfei_api_secret_here
XUNFEI_API_KEY=your_xunfei_api_key_here

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/your_database?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# 邮箱配置 (QQ邮箱)
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code_here
